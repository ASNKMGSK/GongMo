# 로컬 dev 템플릿 — `.env.local` 로 복사해서 사용.
# `_launch_server.ps1` 이 이 파일을 자동 로드. EC2 배포에는 영향 없음.
#
# 사용: cp .env.local.example .env.local ; 경로/값 본인 환경에 맞게 수정

# GT 엑셀 경로 — 본인 PC 의 Desktop 경로로 수정
QA_GT_XLSX_PATH=C:\Users\<USERNAME>\Desktop\QA정답-STT_기반_통합_상담평가표_v3재평가_fixed.xlsx

# Bedrock / AWS
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# 로깅
LOG_LEVEL=INFO
QA_LOG_DEBUG=0

# 토론 모드
# MAX_PARALLEL: 동시 토론 수. Bedrock throttle 위험 — 3이 안정선.
# STAGGER_SEC: worker 간 시작 지연 (초). parallel 올리면 같이 올려 burst 완화.
QA_DEBATE_ENABLED=true
QA_DEBATE_MAX_PARALLEL=3
QA_DEBATE_STAGGER_SEC=3.0
QA_DEBATE_MAX_ROUNDS=2
QA_DEBATE_SPEAKER_SELECTION=round_robin
QA_DEBATE_TEMPERATURE=0.3

# 서버 포트
PORT=8081
