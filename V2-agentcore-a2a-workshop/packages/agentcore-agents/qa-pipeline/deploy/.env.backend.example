# QA Pipeline V3 — 백엔드 환경변수 템플릿 (EC2 /opt/qa-pipeline/.env 로 복사)
# 실행 전 값 검토 · 배포 스크립트가 자동 복사하지 않음 (수동 복사 권장)

AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# 로깅
LOG_LEVEL=INFO
QA_LOG_DEBUG=0

# LLM 동시 요청 세마포어 (Bedrock 기본 10)
SAGEMAKER_MAX_CONCURRENT=10

# 토론 모드
QA_DEBATE_ENABLED=true
QA_DEBATE_MAX_PARALLEL=1
QA_DEBATE_MAX_ROUNDS=2
QA_DEBATE_MAX_ITEMS=0
QA_DEBATE_SPEAKER_SELECTION=round_robin
QA_DEBATE_TEMPERATURE=0.3
QA_DEBATE_STAGGER_SEC=3.0

# 서버
PORT=8081
